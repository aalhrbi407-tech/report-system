# ---- انسخ هذا الملف إلى .env وعدّل القيم ----
# cp .env.example .env

# منفذ التشغيل
PORT=3000

# قاعدة البيانات (Postgres) — الصق رابط الاتصال من Neon هنا للإنتاج.
# مثال: postgres://user:pass@ep-xxx.neon.tech/neondb?sslmode=require
# إذا تُرك فارغًا، يعمل النظام محليًا بقاعدة PGlite مدمجة (للتطوير فقط) وتُحفظ في data/pg
DATABASE_URL=

# سرّ توقيع الجلسات — سلسلة عشوائية طويلة وسرّية.
# ولّدها بالأمر:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# اجعلها 1 عند التشغيل خلف HTTPS (يفعّل خاصية Secure للكوكيز)
SECURE_COOKIE=0

# بيانات حساب مدير النظام الأول (تُستخدم عند أول تهيئة فقط)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=ChangeMe#2026
ADMIN_NAME=مدير النظام

# هوية الجهة (اختياري)
ORG_NAME=إدارة الجودة وتجربة المستفيد
PROGRAM_NAME=برنامج الزائر السري
